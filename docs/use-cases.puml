  usecase "Gönderiyi Puanla" as UC9

  usecase "Sosyal Paylaşım Yap" as UC10
  usecase "Beğen / Yorum Yap" as UC11
  usecase "Takip Et" as UC12

  usecase "İş İlanı Yayınla" as UC13
  usecase "İşe Başvur" as UC14
  usecase "Proje İlanı Oluştur" as UC15

  usecase "Abonelik Satın Al" as UC16
  usecase "Rozet Kazan" as UC17
}

User --> UC1
User --> UC2
User --> UC3
User --> UC5
User --> UC6
User --> UC7
User --> UC10
User --> UC11
User --> UC12

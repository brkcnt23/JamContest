{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",
    "outDir": "./prisma",
    "rootDir": "./prisma",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "sourceMap": true,
    "declaration": true
  },
  "files": ["prisma/seed.ts", "prisma/seed.social.ts"],
  "exclude": []
}

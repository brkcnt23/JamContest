generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum GlobalRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum ContestRole {
  ORGANIZER
  CO_ORGANIZER
  JURY
  PARTICIPANT
}

enum ContestStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  APPLICATIONS
  ACTIVE
  SUBMISSION_CLOSED
  JUDGING
  FINALIZED
  COMPLETED
  CANCELLED
  REJECTED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApprovalMode {
  MANUAL
  AUTO
}

enum BadgeType {
  EARLY_ADOPTER       // İlk 100 user
  ORGANIZER           // Organizatör olmuş
  JURY_MEMBER         // Jüri olmuş
  FIRST_WIN           // İlk yarışma kazanma
  FIRST_SUBMISSION    // İlk eser teslimi
  SOCIAL_SHARER       // Sosyal medya paylaşımı
  TOP_3               // İlk 3'e girme
  VETERAN             // 5+ yarışmaya katılım
  CONTEST_CREATOR     // İlk yarışma oluşturma
}

// ==========================================
// USER
// ==========================================

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String
  username      String     @unique
  displayName   String?
  bio           String?
  about         String?    @db.Text
  avatar        String?
  tagline       String?
  portfolioLink String?

  galleryImages   String[] @default([])
  galleryArtworks Json     @default("[]")

  contactEmail      String?
  contactInstagram  String?
  contactTwitter    String?
  contactBehance    String?
  contactArtStation String?

  globalRole    GlobalRole @default(USER)
  emailVerified Boolean    @default(false)

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  contestMembers     ContestMember[]
  applications       ContestApplication[]
  submissions        Submission[]
  scores             JuryScore[]
  badges             UserBadge[]
  createdContests    Contest[]            @relation("ContestCreator")
  socialShares       SocialShare[]
  contestApprovals   ContestApproval[]
  userBans           UserBan[]            @relation("BannedUser")
  bannedByRecords    UserBan[]            @relation("BannedByUser")
  juryInvitationsSent JuryInvitation[]    @relation("InviterUser")
  juryInvitationsReceived JuryInvitation[] @relation("InvitedUser")
  editRequestsMade   ContestEditRequest[]
  cancelRequestsMade ContestCancelRequest[]
  refreshTokens      RefreshToken[]
  emailVerifications EmailVerification[]
  notifications      Notification[]
  favorites          ContestFavorite[]
  conversations      ConversationParticipant[]
  sentMessages       Message[]

  @@index([username])
  @@index([email])
  @@index([globalRole])
}

// ==========================================
// CONTEST (Yarışma / Game Jam / Organizasyon)
// ==========================================

model Contest {
  id                String        @id @default(cuid())
  title             String
  description       String        @db.Text
  slug              String        @unique
  coverImage        String?

  // Yarışmayı oluşturan kişi
  createdById       String
  createdBy         User          @relation("ContestCreator", fields: [createdById], references: [id])

  // Tarihler
  applicationStart  DateTime?
  applicationEnd    DateTime?
  topicRevealAt     DateTime?
  submissionStart   DateTime?
  submissionEnd     DateTime?
  judgingStart       DateTime?
  judgingEnd         DateTime?

  // İçerik
  topic             String?       @db.Text
  rules             String?       @db.Text
  prizes            String?       @db.Text
  category          String?       // "game_jam", "contest", "hackathon" vs.

  // Ayarlar
  maxParticipants   Int?
  approvalMode      ApprovalMode  @default(MANUAL)  // Katılımcı onay modu
  maxFileSize       Int           @default(209715200)
  allowedFormats    String[]

  // Durum
  status            ContestStatus @default(DRAFT)
  reviewStatus      String        @default("DRAFT") // DRAFT, REVIEW_PENDING, APPROVED, CANCELLED

  // Admin onay süreci
  adminApprovalNote String?       @db.Text  // Red sebebi vs.

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relations
  members           ContestMember[]
  applications      ContestApplication[]
  submissions       Submission[]
  approvals         ContestApproval[]
  juryInvitations   JuryInvitation[]
  editRequests      ContestEditRequest[]
  cancelRequest     ContestCancelRequest?
  favorites         ContestFavorite[]

  @@index([status])
  @@index([slug])
  @@index([createdById])
}

// ==========================================
// CONTEST MEMBER (Yarışma bazlı roller)
// ==========================================
// Bir user aynı anda farklı yarışmalarda farklı rollere sahip olabilir.
// X yarışmasında JURY, Y yarışmasında PARTICIPANT, Z yarışmasında ORGANIZER

model ContestMember {
  id          String      @id @default(cuid())
  userId      String
  contestId   String
  role        ContestRole

  assignedAt  DateTime    @default(now())
  assignedBy  String?     // Kim atadı

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  contest     Contest     @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@unique([userId, contestId, role])
  @@index([contestId, role])
  @@index([userId])
}

// ==========================================
// CONTEST APPROVAL (Admin onay süreci)
// ==========================================

model ContestApproval {
  id          String   @id @default(cuid())
  contestId   String
  reviewerId  String   // Onaylayan/reddeden admin
  decision    String   // "APPROVED" | "REJECTED"
  note        String?  @db.Text

  createdAt   DateTime @default(now())

  contest     Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  reviewer    User     @relation(fields: [reviewerId], references: [id])

  @@index([contestId])
}

// ==========================================
// CONTEST APPLICATION (Katılım başvurusu)
// ==========================================

model ContestApplication {
  id          String            @id @default(cuid())
  userId      String
  contestId   String
  status      ApplicationStatus @default(PENDING)
  message     String?           @db.Text

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  contest     Contest           @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@unique([userId, contestId])
  @@index([contestId, status])
}

// ==========================================
// SUBMISSION (Eser teslimi)
// ==========================================

model Submission {
  id          String   @id @default(cuid())
  userId      String
  contestId   String

  title       String
  description String?  @db.Text
  link        String?  // Drive/Wetransfer linki

  files       SubmissionFile[]
  scores      JuryScore[]
  finalScore  Float?
  rank        Int?

  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contest     Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@unique([userId, contestId])
  @@index([contestId, finalScore])
}

model SubmissionFile {
  id           String   @id @default(cuid())
  submissionId String

  filename     String
  originalName String
  filepath     String
  mimeType     String
  size         Int

  uploadedAt   DateTime @default(now())

  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
}

// ==========================================
// JURY SCORE (Jüri oylama - izole & gizli)
// ==========================================
// - Her jüri sadece kendi oyunu verir, başkasının oyunu göremez
// - Oy verdikten sonra tekrar göremez/değiştiremez
// - Katılımcılar sadece toplam skoru görür, kimin ne verdiğini değil
// - Sadece SUPER_ADMIN tüm detayı görebilir

model JuryScore {
  id           String   @id @default(cuid())
  juryId       String
  submissionId String

  score        Float
  comment      String?  @db.Text
  isLocked     Boolean  @default(true)  // Oy verildikten sonra kilitlenir
  archivedAt   DateTime?
  archivedBy   String?

  createdAt    DateTime @default(now())

  jury         User       @relation(fields: [juryId], references: [id], onDelete: Cascade)
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([juryId, submissionId])
  @@index([submissionId])
}

// ==========================================
// BADGE SİSTEMİ
// ==========================================

model Badge {
  id          String    @id @default(cuid())
  type        BadgeType @unique
  name        String
  description String
  icon        String?   // emoji veya icon path
  color       String?   // hex renk

  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())
  metadata  Json?    // ek bilgi: hangi yarışma, kaçıncı user vs.

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

// ==========================================
// SOCIAL SHARE (Paylaşım takibi - badge için)
// ==========================================

model SocialShare {
  id        String   @id @default(cuid())
  userId    String
  platform  String   // "twitter", "instagram", "linkedin" vs.
  url       String?
  contestId String?

  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ==========================================
// USER BAN SYSTEM
// ==========================================

model UserBan {
  id            String   @id @default(cuid())
  userId        String
  bannedBy      String
  reason        String   @db.Text
  restrictions  String[] // ["APPLY", "POST", "SUBMIT", "CREATE_CONTEST"]
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation("BannedUser", fields: [userId], references: [id], onDelete: Cascade)
  bannedByUser  User     @relation("BannedByUser", fields: [bannedBy], references: [id])

  @@index([userId])
  @@index([active])
}

// ==========================================
// JURY INVITATION SYSTEM
// ==========================================

model JuryInvitation {
  id          String    @id @default(cuid())
  contestId   String
  userId      String
  invitedBy   String
  status      String    @default("PENDING") // PENDING, ACCEPTED, REJECTED, CANCELLED
  cancelledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  contest     Contest   @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user        User      @relation("InvitedUser", fields: [userId], references: [id], onDelete: Cascade)
  inviter     User      @relation("InviterUser", fields: [invitedBy], references: [id])

  @@unique([contestId, userId])
  @@index([userId, status])
  @@index([contestId])
}

// ==========================================
// CONTEST EDIT REQUEST
// ==========================================

model ContestEditRequest {
  id          String   @id @default(cuid())
  contestId   String
  requestedBy String
  changes     Json     // hangi alanlar değişecek
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  adminNote   String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contest     Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  requester   User     @relation(fields: [requestedBy], references: [id], onDelete: Cascade)

  @@index([contestId, status])
  @@index([status])
}

// ==========================================
// CONTEST CANCEL REQUEST
// ==========================================

model ContestCancelRequest {
  id          String   @id @default(cuid())
  contestId   String   @unique
  requestedBy String
  reason      String   @db.Text
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  adminNote   String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contest     Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  requester   User     @relation(fields: [requestedBy], references: [id], onDelete: Cascade)

  @@index([status])
}

// ==========================================
// REFRESH TOKEN SYSTEM
// ==========================================

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  userAgent String?
  ip        String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ==========================================
// EMAIL VERIFICATION
// ==========================================

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// NOTIFICATION SYSTEM
// ==========================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // JURY_INVITATION | CONTEST_APPROVED | CONTEST_REJECTED | SUBMISSION_RESULT | SYSTEM
  title     String
  body      String
  link      String?  // frontend route
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ==========================================
// CONTEST FAVORITE SYSTEM
// ==========================================

model ContestFavorite {
  id        String   @id @default(cuid())
  userId    String
  contestId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@unique([userId, contestId])
  @@index([userId])
}

// ==========================================
// DIRECT MESSAGE SYSTEM
// ==========================================

model Conversation {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  @@index([updatedAt])
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  body           String   @db.Text
  createdAt      DateTime @default(now())
  editedAt       DateTime?
  deletedAt      DateTime?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum GlobalRole {
  USER
  ADMIN
  SUPER_ADMIN
  JURY
  ORGANIZER
}

enum ContestRole {
  ORGANIZER
  CO_ORGANIZER
  JURY
  PARTICIPANT
}

enum ContestStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  APPLICATIONS
  ACTIVE
  SUBMISSION_CLOSED
  JUDGING
  FINALIZED
  COMPLETED
  CANCELLED
  REJECTED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApprovalMode {
  MANUAL
  AUTO
}

enum BadgeType {
  EARLY_ADOPTER
  ORGANIZER
  JURY_MEMBER
  FIRST_WIN
  FIRST_SUBMISSION
  SOCIAL_SHARER
  TOP_3
  VETERAN
  CONTEST_CREATOR
}

// ==========================================
// USER
// ==========================================

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String
  username      String     @unique
  displayName   String?
  bio           String?
  about         String?    @db.Text
  avatar        String?
  tagline       String?
  portfolioLink String?

  galleryImages   String[] @default([])
  galleryArtworks Json     @default("[]")

  contactEmail      String?
  contactInstagram  String?
  contactTwitter    String?
  contactBehance    String?
  contactArtStation String?

  globalRole    GlobalRole @default(USER)
  language      String     @default("tr")
  emailVerified Boolean    @default(false)

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  contestMembers     ContestMember[]
  applications       ContestApplication[]
  submissions        Submission[]
  scores             JuryScore[]
  badges             UserBadge[]
  createdContests    Contest[]            @relation("ContestCreator")
  socialShares       SocialShare[]
  contestApprovals   ContestApproval[]
  userBans           UserBan[]            @relation("BannedUser")
  bannedByRecords    UserBan[]            @relation("BannedByUser")
  juryInvitationsSent JuryInvitation[]    @relation("InviterUser")
  juryInvitationsReceived JuryInvitation[] @relation("InvitedUser")
  editRequestsMade   ContestEditRequest[]
  cancelRequestsMade ContestCancelRequest[]
  refreshTokens      RefreshToken[]
  emailVerifications EmailVerification[]
  notifications      Notification[]
  favorites          ContestFavorite[]
  conversations      ConversationParticipant[]
  sentMessages       Message[]
  juryApplications   JuryApplication[]     @relation("JuryApplicationUser")
  organizerApplications OrganizerApplication[] @relation("OrganizerApplicationUser")
  juryReviews        JuryReview[]          @relation("juryReviews")
  followers          Follow[]              @relation("Following")
  following          Follow[]              @relation("FollowedBy")
  likes              Like[]                @relation("Likes")
  comments           Comment[]             @relation("Comments")

  @@index([username])
  @@index([email])
  @@index([globalRole])
}

// ==========================================
// CONTEST
// ==========================================

model Contest {
  id                String        @id @default(cuid())
  title             String
  description       String        @db.Text
  slug              String        @unique
  coverImage        String?

  createdById       String
  createdBy         User          @relation("ContestCreator", fields: [createdById], references: [id])

  applicationStart  DateTime?
  applicationEnd    DateTime?
  topicRevealAt     DateTime?
  submissionStart   DateTime?
  submissionEnd     DateTime?
  judgingStart      DateTime?
  judgingEnd        DateTime?

  topic             String?       @db.Text
  rules             String?       @db.Text
  prizes            String?       @db.Text
  category          String?

  maxParticipants   Int?
  approvalMode      ApprovalMode  @default(MANUAL)
  maxFileSize       Int           @default(209715200)
  allowedFormats    String[]

  status            ContestStatus @default(DRAFT)
  reviewStatus      String        @default("DRAFT")

  adminApprovalNote String?       @db.Text

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relations
  members           ContestMember[]
  applications      ContestApplication[]
  submissions       Submission[]
  approvals         ContestApproval[]
  juryInvitations   JuryInvitation[]
  editRequests      ContestEditRequest[]
  cancelRequest     ContestCancelRequest?
  favorites         ContestFavorite[]

  @@index([status])
  @@index([slug])
  @@index([createdById])
}

// ==========================================
// CONTEST MEMBER
// ==========================================

model ContestMember {
  id          String      @id @default(cuid())
  userId      String
  contestId   String
  role        ContestRole

  assignedAt  DateTime    @default(now())
  assignedBy  String?

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  contest     Contest     @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@unique([userId, contestId, role])
  @@index([contestId, role])
  @@index([userId])
}

// ==========================================
// CONTEST APPROVAL
// ==========================================

model ContestApproval {
  id          String   @id @default(cuid())
  contestId   String
  reviewerId  String
  decision    String
  note        String?  @db.Text

  createdAt   DateTime @default(now())

  contest     Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  reviewer    User     @relation(fields: [reviewerId], references: [id])

  @@index([contestId])
}

// ==========================================
// CONTEST APPLICATION
// ==========================================

model ContestApplication {
  id          String            @id @default(cuid())
  userId      String
  contestId   String
  status      ApplicationStatus @default(PENDING)
  message     String?           @db.Text

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  contest     Contest           @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@unique([userId, contestId])
  @@index([contestId, status])
}

// ==========================================
// SUBMISSION
// ==========================================

model Submission {
  id          String   @id @default(cuid())
  userId      String
  contestId   String

  title       String
  description String?  @db.Text
  link        String?

  files       SubmissionFile[]
  scores      JuryScore[]
  reviews     JuryReview[]        @relation("submissionReviews")
  likes       Like[]              @relation("Likes")
  comments    Comment[]           @relation("Comments")
  finalScore  Float?
  rank        Int?

  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contest     Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@unique([userId, contestId])
  @@index([contestId, finalScore])
}

model SubmissionFile {
  id           String   @id @default(cuid())
  submissionId String

  filename     String
  originalName String
  filepath     String
  mimeType     String
  size         Int

  uploadedAt   DateTime @default(now())

  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
}

// ==========================================
// JURY SCORE
// ==========================================

model JuryScore {
  id           String   @id @default(cuid())
  juryId       String
  submissionId String

  score        Float
  comment      String?  @db.Text
  isLocked     Boolean  @default(true)
  archivedAt   DateTime?
  archivedBy   String?

  createdAt    DateTime @default(now())

  jury         User       @relation(fields: [juryId], references: [id], onDelete: Cascade)
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([juryId, submissionId])
  @@index([submissionId])
}

// ==========================================
// BADGE SYSTEM
// ==========================================

model Badge {
  id          String    @id @default(cuid())
  type        BadgeType @unique
  name        String
  description String
  icon        String?
  color       String?

  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())
  metadata  Json?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

// ==========================================
// SOCIAL SHARE
// ==========================================

model SocialShare {
  id        String   @id @default(cuid())
  userId    String
  platform  String
  url       String?
  contestId String?

  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ==========================================
// USER BAN SYSTEM
// ==========================================

model UserBan {
  id            String   @id @default(cuid())
  userId        String
  bannedBy      String
  reason        String   @db.Text
  restrictions  String[]
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation("BannedUser", fields: [userId], references: [id], onDelete: Cascade)
  bannedByUser  User     @relation("BannedByUser", fields: [bannedBy], references: [id])

  @@index([userId])
  @@index([active])
}

// ==========================================
// JURY INVITATION SYSTEM
// ==========================================

model JuryInvitation {
  id          String    @id @default(cuid())
  contestId   String
  userId      String
  invitedBy   String
  status      String    @default("PENDING")
  cancelledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  contest     Contest   @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user        User      @relation("InvitedUser", fields: [userId], references: [id], onDelete: Cascade)
  inviter     User      @relation("InviterUser", fields: [invitedBy], references: [id])

  @@unique([contestId, userId])
  @@index([userId, status])
  @@index([contestId])
}

// ==========================================
// CONTEST EDIT REQUEST
// ==========================================

model ContestEditRequest {
  id          String   @id @default(cuid())
  contestId   String
  requestedBy String
  changes     Json
  status      String   @default("PENDING")
  adminNote   String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contest     Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  requester   User     @relation(fields: [requestedBy], references: [id], onDelete: Cascade)

  @@index([contestId, status])
  @@index([status])
}

// ==========================================
// CONTEST CANCEL REQUEST
// ==========================================

model ContestCancelRequest {
  id          String   @id @default(cuid())
  contestId   String   @unique
  requestedBy String
  reason      String   @db.Text
  status      String   @default("PENDING")
  adminNote   String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contest     Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  requester   User     @relation(fields: [requestedBy], references: [id], onDelete: Cascade)

  @@index([status])
}

// ==========================================
// REFRESH TOKEN SYSTEM
// ==========================================

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  userAgent String?
  ip        String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ==========================================
// EMAIL VERIFICATION
// ==========================================

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// NOTIFICATION SYSTEM
// ==========================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ==========================================
// CONTEST FAVORITE SYSTEM
// ==========================================

model ContestFavorite {
  id        String   @id @default(cuid())
  userId    String
  contestId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@unique([userId, contestId])
  @@index([userId])
}

// ==========================================
// DIRECT MESSAGE SYSTEM
// ==========================================

model Conversation {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  @@index([updatedAt])
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  body           String   @db.Text
  createdAt      DateTime @default(now())
  editedAt       DateTime?
  deletedAt      DateTime?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// ==========================================
// APPLICATIONS
// ==========================================

model JuryApplication {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation("JuryApplicationUser", fields: [userId], references: [id], onDelete: Cascade)
  
  motivation String  @db.Text
  status    String   @default("PENDING")
  reason    String?  @db.Text
  
  appliedAt    DateTime @default(now())
  reviewedAt   DateTime?
  reviewedBy   String?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([userId])
}

model OrganizerApplication {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation("OrganizerApplicationUser", fields: [userId], references: [id], onDelete: Cascade)
  
  motivation String  @db.Text
  status    String   @default("PENDING")
  reason    String?  @db.Text
  
  appliedAt    DateTime @default(now())
  reviewedAt   DateTime?
  reviewedBy   String?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([userId])
}

model JuryReview {
  id           String   @id @default(cuid())
  submissionId String
  submission   Submission @relation("submissionReviews", fields: [submissionId], references: [id], onDelete: Cascade)
  
  juryId       String
  jury         User     @relation("juryReviews", fields: [juryId], references: [id], onDelete: Cascade)
  
  score        Int      @default(0)
  comment      String?  @db.Text
  status       String   @default("DRAFT")
  
  submittedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([submissionId, juryId])
  @@index([status])
  @@index([submissionId])
  @@index([juryId])
}

// ==========================================
// SOCIAL FEATURES
// ==========================================

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("FollowedBy", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Like {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("Likes", fields: [userId], references: [id], onDelete: Cascade)
  submissionId String
  submission   Submission @relation("Likes", fields: [submissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@unique([userId, submissionId])
  @@index([userId])
  @@index([submissionId])
}

model Comment {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("Comments", fields: [userId], references: [id], onDelete: Cascade)
  submissionId String
  submission   Submission @relation("Comments", fields: [submissionId], references: [id], onDelete: Cascade)
  content      String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([submissionId])
}

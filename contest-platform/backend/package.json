{
  "name": "backend",
  "version": "0.0.1",
  "scripts": {
    "start": "nest start",
    "start:dev": "dotenv -e .env.local -- nest start --watch",
    "build": "nest build",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:seed": "node prisma/seed.js",
    "prisma:studio": "prisma studio",
    "prisma:reset": "prisma migrate reset --force",
    "local:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "local:generate": "dotenv -e .env.local -- prisma generate",
    "local:seed:build": "tsc -p tsconfig.seed.json",
    "local:seed": "dotenv -e .env.local -- node prisma/seed.js",
    "local:studio": "dotenv -e .env.local -- prisma studio",
    "local:reset": "dotenv -e .env.local -- prisma migrate reset --force",
    "local:setup": "pnpm local:migrate && pnpm local:generate && pnpm local:seed:build && pnpm local:seed"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/schedule": "^4.1.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^10.3.0",
    "@prisma/client": "^5.22.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/nodemailer": "^7.0.11",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.0",
    "@types/passport-jwt": "^4.0.0",
    "dotenv-cli": "^7.4.2",
    "prisma": "^5.22.0",
    "typescript": "^5.3.3"
  }
}
